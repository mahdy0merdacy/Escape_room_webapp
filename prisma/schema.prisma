generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Room {
  id                String    @id @default(cuid())
  slug              String    @unique
  name              String
  tagline           String
  story             String
  heroImageUrl      String
  trailerUrl        String    @default("")
  galleryImageUrls  String
  themeColors       String
  themeFont         String
  difficulty        Int
  durationMinutes   Int
  minPlayers        Int
  maxPlayers        Int
  pricePerPerson    Float
  openHours         String
  active            Boolean   @default(true)
  roomStatus        String    @default("active")
  showGallery       Boolean   @default(true)
  order             Int       @default(0)
  seoTitle          String
  seoDescription    String
  successRate       Float     @default(0)
  bookings          Booking[]
  blockedSlots      BlockedSlot[]
  leaderboardEntries LeaderboardEntry[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model LeaderboardEntry {
  id            String   @id @default(cuid())
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId        String
  groupName     String
  partySize     Int
  timeSpentSec  Int
  completedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([roomId, timeSpentSec])
}

model BlockedSlot {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  slotStart DateTime
  createdAt DateTime @default(now())

  @@unique([roomId, slotStart])
}

model Booking {
  id           String        @id @default(cuid())
  room         Room          @relation(fields: [roomId], references: [id])
  roomId       String
  startTime    DateTime
  endTime      DateTime
  customerName String
  email        String
  phone        String
  partySize    Int
  paid            Boolean       @default(false)
  amountPaid      Float?
  confirmedPlayed Boolean       @default(false)
  status          String        @default("confirmed")
  locale          String        @default("en")
  gameLanguage    String        @default("fr")
  createdAt       DateTime      @default(now())

  // No @@unique here on purpose. Double-booking protection on (roomId, startTime)
  // is enforced by a PARTIAL unique index (WHERE status != 'cancelled') added in
  // migration 20260712000000_partial_unique_active_booking — Prisma's schema DSL
  // can't express a filtered index, so it only exists in the migration SQL. Do not
  // add a plain @@unique([roomId, startTime]) back here: a full-table unique index
  // would let a soft-cancelled row permanently block that slot from ever being
  // rebooked, which was the original bug this migration fixed. If you run
  // `prisma migrate dev` and it offers to "fix" drift by dropping this index,
  // decline it.
}

model ScheduleConfig {
  id           String   @id @default("default")
  openHour     Int      @default(11)
  openMinute   Int      @default(0)
  closeHour    Int      @default(1)
  closeMinute  Int      @default(0)
  breakMinutes Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("owner")
  createdAt    DateTime @default(now())
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  body      String
  sentAt    DateTime @default(now())
}

model GalleryAlbum {
  id        String   @id @default(cuid())
  label     String
  sub       String   @default("")
  accent    String   @default("#e11d48")
  imageUrls String   @default("[]")
  featured  Boolean  @default(false)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  active    Boolean  @default(true)
  q_en      String   @default("")
  q_fr      String   @default("")
  q_ar      String   @default("")
  a_en      String   @default("")
  a_fr      String   @default("")
  a_ar      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

model Guide {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  excerpt        String   @default("")
  content        String   @default("")
  titleFr        String   @default("")
  excerptFr      String   @default("")
  contentFr      String   @default("")
  titleAr        String   @default("")
  excerptAr      String   @default("")
  contentAr      String   @default("")
  heroImageUrl   String   @default("")
  pillar         Boolean  @default(false)
  active         Boolean  @default(true)
  order          Int      @default(0)
  seoTitle       String   @default("")
  seoDescription String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
