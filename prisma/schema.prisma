generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Room {
  id                String    @id @default(cuid())
  slug              String    @unique
  name              String
  tagline           String
  story             String
  heroImageUrl      String
  galleryImageUrls  String
  themeColors       String
  themeFont         String
  difficulty        Int
  durationMinutes   Int
  minPlayers        Int
  maxPlayers        Int
  pricePerPerson    Float
  openHours         String
  active            Boolean   @default(true)
  roomStatus        String    @default("active")
  seoTitle          String
  seoDescription    String
  bookings          Booking[]
  blockedSlots      BlockedSlot[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model BlockedSlot {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  slotStart DateTime
  createdAt DateTime @default(now())

  @@unique([roomId, slotStart])
}

model Booking {
  id           String        @id @default(cuid())
  room         Room          @relation(fields: [roomId], references: [id])
  roomId       String
  startTime    DateTime
  endTime      DateTime
  customerName String
  email        String
  phone        String
  partySize    Int
  paid            Boolean       @default(false)
  amountPaid      Float?
  confirmedPlayed Boolean       @default(false)
  status          String        @default("confirmed")
  createdAt       DateTime      @default(now())

  @@unique([roomId, startTime])
}

model ScheduleConfig {
  id           String   @id @default("default")
  openHour     Int      @default(11)
  openMinute   Int      @default(0)
  closeHour    Int      @default(1)
  closeMinute  Int      @default(0)
  breakMinutes Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  body      String
  sentAt    DateTime @default(now())
}

model GalleryAlbum {
  id        String   @id @default(cuid())
  label     String
  sub       String   @default("")
  accent    String   @default("#e11d48")
  featured  Boolean  @default(false)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  active    Boolean  @default(true)
  q_en      String   @default("")
  q_fr      String   @default("")
  q_ar      String   @default("")
  a_en      String   @default("")
  a_fr      String   @default("")
  a_ar      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}
